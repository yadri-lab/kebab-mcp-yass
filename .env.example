# ===================================================================
# MyMCP — Personal MCP Framework
# Copy this file to .env and fill in your values
# ===================================================================

# --- Authentication ---

# MCP endpoint auth token (required)
# Used by Claude Desktop / MCP clients to authenticate
# Generate: openssl rand -hex 32
# Multi-client: comma-separate tokens, one per client
# Example: MCP_AUTH_TOKEN=token-for-claude,token-for-chatgpt
MCP_AUTH_TOKEN=

# Admin dashboard auth token (optional)
# If not set, falls back to MCP_AUTH_TOKEN
# Separate token recommended so MCP clients can't access dashboard
ADMIN_AUTH_TOKEN=

# --- Google Workspace Connector ---
# Enables: Gmail (9 tools), Calendar (6), Contacts (1), Drive (2)
# Setup: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Obsidian Vault Connector ---
# Enables: 15 vault tools (read, write, search, backlinks, etc.)

# GitHub PAT with `repo` scope: https://github.com/settings/tokens
GITHUB_PAT=
# Repo in owner/repo format
GITHUB_REPO=
# Default branch (default: main)
# GITHUB_BRANCH=main

# --- Browser Automation Connector (optional) ---
# Enables: web_browse, web_extract, web_act, linkedin_feed

# https://browserbase.com → Settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Persistent LinkedIn session context (optional)
BROWSERBASE_CONTEXT_LINKEDIN=

# --- Slack Connector (optional) ---
# Enables: slack_channels, slack_read, slack_send, slack_search, slack_thread, slack_profile

# Bot User OAuth Token: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=
# User token for search (optional, bot token works for most features)
# SLACK_USER_TOKEN=

# --- Notion Connector (optional) ---
# Enables: notion_search, notion_read, notion_create, notion_update, notion_query

# Internal Integration Token: https://www.notion.so/my-integrations
NOTION_API_KEY=

# --- Apify Connector (optional) ---
# Enables: 6 LinkedIn scrapers + apify_search_actors + apify_run_actor
# Get token: https://console.apify.com/account/integrations

APIFY_TOKEN=
# Optional allowlist of actor IDs (comma-separated). Empty = all 6 wrappers load.
# APIFY_ACTORS=harvestapi/linkedin-company,harvestapi/linkedin-profile-scraper

# --- GitHub Issues Connector (optional) ---
# Enables: github_list_issues, github_get_issue, github_create_issue, github_update_issue, github_add_comment, github_search_issues

# Personal access token (classic) or fine-grained PAT with `issues:write` scope
# https://github.com/settings/tokens
GITHUB_TOKEN=
# Default repository in owner/repo format (e.g. myorg/myrepo)
# Tools accept a per-call `repo` param that overrides this value
# GITHUB_DEFAULT_REPO=

# --- Linear Connector (optional) ---
# Enables: linear_list_issues, linear_get_issue, linear_search_issues, linear_list_projects, linear_create_issue, linear_update_issue

# API key from https://linear.app → Settings → API → Personal API keys
LINEAR_API_KEY=

# --- Airtable Connector (optional) ---
# Enables: airtable_list_bases, airtable_list_tables, airtable_list_records, airtable_get_record, airtable_create_record, airtable_update_record, airtable_search_records

# Personal access token from https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# --- Composio Connector (optional) ---
# Enables: composio_action, composio_list (1000+ app integrations)

# API key from https://composio.dev → Settings
COMPOSIO_API_KEY=
# Entity ID for connected accounts (default: "default")
# COMPOSIO_ENTITY_ID=default

# --- Instance Customization (all optional) ---

# Set to "personal" to use this deployment as your own instance.
# When unset (default), the root route shows the marketing landing page.
# When set to "personal", the root route redirects to your dashboard or setup.
# INSTANCE_MODE=personal

MYMCP_TIMEZONE=UTC
MYMCP_LOCALE=en-US
MYMCP_DISPLAY_NAME=User
MYMCP_CONTEXT_PATH=System/context.md

# --- Advanced ---
# MYMCP_DISABLE_GOOGLE=true
# MYMCP_DISABLE_VAULT=true
# MYMCP_DISABLE_BROWSER=true
# MYMCP_ENABLED_PACKS=google,vault,browser,admin
# MEDIUM_SID=

# Tool timeout in ms (default: 30000)
# MYMCP_TOOL_TIMEOUT=30000

# Error webhook URL — receives POST on tool failures (Slack-compatible)
# MYMCP_ERROR_WEBHOOK_URL=https://hooks.slack.com/services/...

# Durable observability sink — persist tool call logs to KV store (default: false)
# Requires a KV backend (Upstash recommended for production; filesystem for local dev)
# When enabled, mcp_logs tool reads from KV instead of the in-memory ring buffer
MYMCP_DURABLE_LOGS=false

# Per-token rate limiting (default: disabled)
# Limits MCP endpoint calls per token per minute using the KV store
# KV failures are treated as allow (fail open)
MYMCP_RATE_LIMIT_ENABLED=false
# Max requests per token per minute (default: 60)
MYMCP_RATE_LIMIT_RPM=60
