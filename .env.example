# ===================================================================
# MyMCP — Personal MCP Framework
# Copy this file to .env and fill in your values
# ===================================================================

# --- Authentication ---

# MCP endpoint auth token (required)
# Used by Claude Desktop / MCP clients to authenticate
# Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Admin dashboard auth token (optional)
# If not set, falls back to MCP_AUTH_TOKEN
# Separate token recommended so MCP clients can't access dashboard
ADMIN_AUTH_TOKEN=

# --- Google Workspace Pack ---
# Enables: Gmail (9 tools), Calendar (6), Contacts (1), Drive (2)
# Setup: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Obsidian Vault Pack ---
# Enables: 15 vault tools (read, write, search, backlinks, etc.)

# GitHub PAT with `repo` scope: https://github.com/settings/tokens
GITHUB_PAT=
# Repo in owner/repo format
GITHUB_REPO=
# Default branch (default: main)
# GITHUB_BRANCH=main

# --- Browser Automation Pack (optional) ---
# Enables: web_browse, web_extract, web_act, linkedin_feed

# https://browserbase.com → Settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Persistent LinkedIn session context (optional)
BROWSERBASE_CONTEXT_LINKEDIN=

# --- Slack Pack (optional) ---
# Enables: slack_channels, slack_read, slack_send, slack_search, slack_thread, slack_profile

# Bot User OAuth Token: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=
# User token for search (optional, bot token works for most features)
# SLACK_USER_TOKEN=

# --- Notion Pack (optional) ---
# Enables: notion_search, notion_read, notion_create, notion_update, notion_query

# Internal Integration Token: https://www.notion.so/my-integrations
NOTION_API_KEY=

# --- Composio Pack (optional) ---
# Enables: composio_action, composio_list (1000+ app integrations)

# API key from https://composio.dev → Settings
COMPOSIO_API_KEY=
# Entity ID for connected accounts (default: "default")
# COMPOSIO_ENTITY_ID=default

# --- Instance Customization (all optional) ---

MYMCP_TIMEZONE=UTC
MYMCP_LOCALE=en-US
MYMCP_DISPLAY_NAME=User
MYMCP_CONTEXT_PATH=System/context.md

# --- Advanced ---
# MYMCP_DISABLE_GOOGLE=true
# MYMCP_DISABLE_VAULT=true
# MYMCP_DISABLE_BROWSER=true
# MYMCP_ENABLED_PACKS=google,vault,browser,admin
# MEDIUM_SID=

# Tool timeout in ms (default: 30000)
# MYMCP_TOOL_TIMEOUT=30000

# Error webhook URL — receives POST on tool failures (Slack-compatible)
# MYMCP_ERROR_WEBHOOK_URL=https://hooks.slack.com/services/...
