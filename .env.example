# ===================================================================
# Kebab MCP — Personal MCP Framework (formerly MyMCP)
# Copy this file to .env and fill in your values
#
# Note on env var prefixes:
# - MCP_*       → MCP protocol (auth, transport)
# - MYMCP_*     → instance config (legacy prefix kept for compatibility
#                  with existing deployments — do not rename to KEBAB_MCP_*)
# - Connector-specific prefixes: GOOGLE_*, GITHUB_*, NOTION_*, etc.
# ===================================================================

# --- Authentication ---

# MCP endpoint auth token (required)
# Used by Claude Desktop / MCP clients to authenticate
# Generate: openssl rand -hex 32
# Multi-client: comma-separate tokens, one per client
# Example: MCP_AUTH_TOKEN=token-for-claude,token-for-chatgpt
MCP_AUTH_TOKEN=

# Admin dashboard auth token (optional)
# If not set, falls back to MCP_AUTH_TOKEN
# Separate token recommended so MCP clients can't access dashboard
ADMIN_AUTH_TOKEN=

# --- Google Workspace Connector ---
# Enables: Gmail (9 tools), Calendar (6), Contacts (1), Drive (2)
# Setup: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Obsidian Vault Connector ---
# Enables: 14 vault tools (read, write, search, backlinks, etc.)

# GitHub PAT with `repo` scope: https://github.com/settings/tokens
GITHUB_PAT=
# Repo in owner/repo format
GITHUB_REPO=
# Default branch (default: main)
# GITHUB_BRANCH=main

# --- Browser Automation Connector (optional) ---
# Enables: web_browse, web_extract, web_act, linkedin_feed

# https://browserbase.com → Settings
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Persistent LinkedIn session context (optional)
BROWSERBASE_CONTEXT_LINKEDIN=
# (removed in v0.1.14: KEBAB_BROWSER_CONNECTOR_V2 flag. The V2/V3
# dispatch was a placeholder; both paths always delegated to the same
# implementation. Stagehand 3.2.x is the only path now.)

# --- Slack Connector (optional) ---
# Enables: slack_channels, slack_read, slack_send, slack_search, slack_thread, slack_profile

# Bot User OAuth Token: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=
# User token for search (optional, bot token works for most features)
# SLACK_USER_TOKEN=

# --- Notion Connector (optional) ---
# Enables: notion_search, notion_read, notion_create, notion_update, notion_query

# Internal Integration Token: https://www.notion.so/my-integrations
NOTION_API_KEY=

# --- Apify Connector (optional) ---
# Enables: 6 LinkedIn scrapers + apify_search_actors + apify_run_actor
# Get token: https://console.apify.com/account/integrations

APIFY_TOKEN=
# Optional allowlist of actor IDs (comma-separated). Empty = all 6 wrappers load.
# APIFY_ACTORS=harvestapi/linkedin-company,harvestapi/linkedin-profile-scraper

# --- GitHub Issues Connector (optional) ---
# Enables: github_list_issues, github_get_issue, github_create_issue, github_update_issue, github_add_comment, github_search_issues

# Personal access token (classic) or fine-grained PAT with `issues:write` scope
# https://github.com/settings/tokens
GITHUB_TOKEN=
# Default repository in owner/repo format (e.g. myorg/myrepo)
# Tools accept a per-call `repo` param that overrides this value
# GITHUB_DEFAULT_REPO=

# --- Linear Connector (optional) ---
# Enables: linear_list_issues, linear_get_issue, linear_search_issues, linear_list_projects, linear_create_issue, linear_update_issue

# API key from https://linear.app → Settings → API → Personal API keys
LINEAR_API_KEY=

# --- Airtable Connector (optional) ---
# Enables: airtable_list_bases, airtable_list_tables, airtable_list_records, airtable_get_record, airtable_create_record, airtable_update_record, airtable_search_records

# Personal access token from https://airtable.com/create/tokens
AIRTABLE_API_KEY=

# --- Composio Connector (optional) ---
# Enables: composio_action, composio_list (1000+ app integrations)

# API key from https://composio.dev → Settings
COMPOSIO_API_KEY=
# Entity ID for connected accounts (default: "default")
# COMPOSIO_ENTITY_ID=default

# --- Webhook Receiver (optional) ---
# Comma-separated list of webhook names to accept (e.g., stripe,github)
# MYMCP_WEBHOOKS=stripe,github
# Per-webhook HMAC-SHA256 secret (optional, validates x-webhook-signature header)
# MYMCP_WEBHOOK_SECRET_STRIPE=whsec_...
# MYMCP_WEBHOOK_SECRET_GITHUB=...
# Max history entries per webhook (default: 10). Older entries are pruned.
# MYMCP_WEBHOOK_HISTORY_SIZE=10

# --- Multi-tenant (optional) ---
# Tenant-specific MCP auth tokens. Clients send x-mymcp-tenant header.
# MCP_AUTH_TOKEN_<TENANT_ID>=token (hyphens in tenant ID become underscores)
# MCP_AUTH_TOKEN_ACME=...

# --- Instance Customization (all optional) ---

# Set to "personal" to use this deployment as your own instance.
# When unset (default), the root route shows the marketing landing page.
# When set to "personal", the root route redirects to your dashboard or setup.
# INSTANCE_MODE=personal

MYMCP_TIMEZONE=UTC
MYMCP_LOCALE=en-US
MYMCP_DISPLAY_NAME=User
MYMCP_CONTEXT_PATH=System/context.md

# --- Advanced ---
# v0.6 NIT-05 + HIGH-1: opt-in to client-supplied loopback signals.
# By default `isLoopbackRequest` (used by first-run /api/setup/* routes)
# ignores the URL host AND the x-forwarded-for / x-real-ip headers on
# non-Vercel deploys — both are spoofable unless something in front
# strips them. Set to "1" only when you run `next dev` with no proxy in
# front, or when you run behind a proxy that you KNOW sanitizes both the
# Host header and forwarded-IP headers from the public internet.
# MYMCP_TRUST_URL_HOST=1

# MYMCP_DISABLE_GOOGLE=true
# MYMCP_DISABLE_VAULT=true
# MYMCP_DISABLE_BROWSER=true
# MYMCP_DISABLE_GITHUB=true
# MYMCP_DISABLE_NOTION=true
# MYMCP_ENABLED_PACKS=google,vault,browser,admin
# MEDIUM_SID=
# Disable hot .env editing API (default: false)
# MYMCP_DISABLE_UPDATE_API=true
# Override KV store file path (default: ./data/kv.json)
# MYMCP_KV_PATH=./data/kv.json
# Override skills JSON file path (default: ./data/skills.json)
# MYMCP_SKILLS_PATH=./data/skills.json

# Tool timeout in ms (default: 30000)
# MYMCP_TOOL_TIMEOUT=30000

# Graceful shutdown drain duration in milliseconds (default: 5000, min: 1000).
# Applies to persistent-process deployments (Docker, Fly, Render, Cloud Run,
# bare-metal) via the server.js wrapper. On SIGTERM/SIGINT, in-flight
# requests flush naturally and the process exits after the drain window.
# Ignored on Vercel (lambdas are SIGKILL'd by the runtime).
# See docs/HOSTING.md §SIGTERM handling for per-host tuning.
# MYMCP_SHUTDOWN_TIMEOUT_MS=5000

# Error webhook URL — receives POST on tool failures (Slack-compatible)
# MYMCP_ERROR_WEBHOOK_URL=https://hooks.slack.com/services/...

# Durable observability sink — persist tool call logs to KV store (default: false).
# Requires a KV backend (Upstash recommended for production; filesystem for local dev).
# When enabled, the mcp_logs tool reads from KV instead of the in-memory ring buffer.
#
# HOST-06: MUST be set to `true` (or `1`) for multi-replica deployments
# (Docker N-replica, Fly multi-machine, Render, Cloud Run).
# Single-replica and Vercel deploys work fine with the default.
MYMCP_DURABLE_LOGS=false
# Each replica holds its own in-process ring buffer by default — logs
# split across replicas become non-deterministic without KV aggregation.
# See docs/HOSTING.md §"Durable logs mandatory for N-replica" for why
# and per-host guidance.

# Log retention (only meaningful when MYMCP_DURABLE_LOGS=true)
# Max entries kept in the LogStore (ring buffer / LTRIM length / JSONL cap)
# MYMCP_LOG_MAX_ENTRIES=500
# Optional TTL in seconds — Upstash list key expires after this window
# MYMCP_LOG_MAX_AGE_SECONDS=604800
# Number of rotated JSONL segments to keep (FilesystemLogStore only, default: 3)
# MYMCP_LOG_ROTATE_SEGMENTS=3

# In-process ring buffer cap per tenant (default: 100). Phase 48 ships
# per-tenant buckets so one noisy tenant cannot evict another's entries;
# Phase 53 metrics aggregation reads from these buckets first before
# falling back to the durable log-store. Raise if you want longer
# rolling windows per tenant in memory.
# KEBAB_LOG_BUFFER_PER_TENANT=100

# --- Observability (Phase 53) ---
# KV quota ceiling used by the /config Health dashboard gauge.
# Default 250 MB = 262,144,000 bytes (Upstash free tier). Override if
# you're on a paid tier so the 80%-warn threshold stays meaningful.
# UPSTASH_FREE_TIER_BYTES=262144000

# Health sample retention window in days (default: 7)
# Deep health checks (GET /api/health?deep=1) write samples to LogStore;
# the /api/admin/health-history endpoint returns samples within this window.
# MYMCP_HEALTH_SAMPLE_RETENTION_DAYS=7

# Per-token rate limiting (default: disabled)
# Limits MCP endpoint calls per token per minute using the KV store
# KV failures are treated as allow (fail open)
MYMCP_RATE_LIMIT_ENABLED=false
# Max requests per token per minute (default: 60)
MYMCP_RATE_LIMIT_RPM=60
# In-memory rate-limit opt-in (HOST-05) — NOT safe across replicas,
# single-process only. Default (unset / anything other than "1") uses
# KV (Upstash or filesystem) so counters converge across replicas.
# Set to "1" only for single-process dev/test where you want to bypass
# KV entirely. See docs/HOSTING.md §"Rate limiting".
# MYMCP_RATE_LIMIT_INMEMORY=0

# --- Storage mode (auto-detected at boot) ---
# MyMCP picks one of three modes based on what's available:
#   1. KV       — Upstash credentials below set + reachable. Saves are instant.
#   2. File     — no KV, but local FS is writable (Docker, dev). Saves go
#                 to ./data/kv.json + .env.
#   3. Static   — no KV, FS is read-only (Vercel without Upstash). Dashboard
#                 saves are disabled; credentials must be set as env vars
#                 here and the instance redeployed for changes to apply.
#                 Per-connector .env stub helpers appear in the dashboard.
# See /config?tab=storage for the live mode of any deployed instance.
#
# --- Upstash KV (optional but recommended for Vercel deploys) ---
#
# Kebab MCP supports TWO env var naming variants, both resolved
# identically by src/core/upstash-env.ts — pick whichever your setup
# naturally provides:
#
# Option A — Manual Upstash setup (free tier at https://upstash.com,
#            no credit card required; copy the REST URL + token from
#            the Upstash dashboard and paste them below):
#   UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
#   UPSTASH_REDIS_REST_TOKEN=
#
# Option B — Vercel Marketplace Upstash KV (auto-injected when you add
#            an Upstash Redis integration via Vercel → Integrations →
#            Upstash → Redis. Do NOT set these manually; Vercel
#            populates them on deploy):
#   KV_REST_API_URL=
#   KV_REST_API_TOKEN=
#
# When both pairs are set, UPSTASH_* takes precedence (explicit wins).
# Without either, Kebab runs with filesystem-only KV (durable in Docker,
# ephemeral on Vercel — token vanishes on cold start after ~15 minutes).
#
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Vercel auto-magic onboarding (optional) ---
# When set alongside VERCEL_PROJECT_ID, the /welcome flow can write the
# minted MCP_AUTH_TOKEN into Vercel env vars and trigger a redeploy
# automatically (zero-config path). Leave unset to use the manual flow
# where the user copies the token into Vercel themselves.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=

# --- Vercel Cron health check (optional) ---
# When set, the /api/cron/health route accepts Bearer auth for an
# hourly health probe (see vercel.json for the cron definition).
# When unset, the cron route is locked to loopback — do NOT run cron
# without setting this if the endpoint is internet-reachable.
# CRON_SECRET=

# --- OpenTelemetry (optional) ---
# When OTEL_SERVICE_NAME is set, MyMCP auto-bootstraps a tracer provider
# with an OTLP HTTP exporter. Tool spans are emitted to the collector at
# OTEL_EXPORTER_OTLP_ENDPOINT (default: http://localhost:4318/v1/traces).
# When neither env var is set, all tracing is a zero-overhead no-op.
# OTEL_SERVICE_NAME=mymcp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# --- Instance mode override ---
# "personal" → / redirects to /config or /welcome
# "showcase" → / renders the marketing landing page (mymcp-home uses this)
# Default auto-detects: MCP_AUTH_TOKEN set → personal, otherwise showcase.
# INSTANCE_MODE=personal

# --- Onboarding override ---
# Set once if you want to force the welcome flow back into first-run
# mode (e.g. after a token rotation) — then remove and redeploy. Leaving
# it set is equivalent to making the welcome page publicly re-claimable.
# MYMCP_RECOVERY_RESET=
