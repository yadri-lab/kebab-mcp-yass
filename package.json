{
  "name": "mymcp",
  "version": "0.2.0",
  "description": "Personal MCP server framework — deploy your AI backend to Vercel in 5 minutes",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "personal",
    "vercel",
    "gmail",
    "calendar",
    "obsidian"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yassinello/mymcp"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ app/",
    "lint:fix": "eslint src/ app/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"app/**/*.{ts,tsx}\"",
    "test:contract": "npx tsx scripts/contract-test.ts",
    "test:registry": "npx tsx scripts/registry-test.ts",
    "test:e2e": "npx tsx scripts/e2e-test.ts",
    "test": "npm run test:registry && npm run test:contract",
    "update": "git remote get-url upstream > /dev/null 2>&1 || git remote add upstream https://github.com/Yassinello/mymcp.git && git fetch upstream && git merge upstream/main",
    "prepare": "husky"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.10.0",
    "@browserbasehq/stagehand": "^3.2.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@tailwindcss/postcss": "^4.2.2",
    "arctic": "^3.7.0",
    "composio-core": "^0.5.39",
    "js-yaml": "^4.1.1",
    "mcp-handler": "^1.1.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
